@model ComputerStoreInventory.Models.InventoryItem

@{
    ViewData["Title"] = "Item Details";
}

<h1>Item Details</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.DateAcquired)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.DateAcquired)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.EquipmentType)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.EquipmentType)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ManufacturingYear)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.ManufacturingYear)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Condition)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Condition)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Manufacturer)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Manufacturer)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Model)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Model)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ScreenSize)</dt>
            <dd class="col-sm-8">@(Model.ScreenSize.HasValue ? $"{Model.ScreenSize:F1} inches" : "N/A")</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.StorageSizeGB)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.StorageSizeGB) GB</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.MemoryGB)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.MemoryGB) GB</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Grade)</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Grade)</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Price)</dt>
            <dd class="col-sm-8">@Model.Price.ToString("C")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
